load('^VIX', start=start_date, end=end_date, progress=False)\n","        \n","        if len(spy) == 0 or len(ief) == 0 or len(vix) == 0:\n","            return None\n","        \n","        # Handle multi-level columns\n","        for df in [spy, ief, vix]:\n","            if isinstance(df.columns, pd.MultiIndex):\n","                df.columns = df.columns.droplevel(1)\n","        \n","        data = pd.DataFrame({\n","            'SPY': spy['Adj Close'],\n","            'IEF': ief['Adj Close'],\n","            'VIX': vix['Close']\n","        }).dropna()\n","        \n","        if len(data) < 100:\n","            return None\n","        \n","        data['SPY_Return'] = data['SPY'].pct_change()\n","        data['IEF_Return'] = data['IEF'].pct_change()\n","        \n","        print(f\"✓ Live data loaded: {len(data)} days\")\n","        return data\n","        \n","    except Exception as e:\n","        print(f\"✗ Live download failed: {e}\")\n","        return None"]},{"cell_type":"code","execution_count":6,"id":"619bedde","metadata":{"execution":{"iopub.execute_input":"2025-12-04T16:15:22.994598Z","iopub.status.busy":"2025-12-04T16:15:22.994203Z","iopub.status.idle":"2025-12-04T16:15:23.010912Z","shell.execute_reply":"2025-12-04T16:15:23.009764Z"},"papermill":{"duration":0.028662,"end_time":"2025-12-04T16:15:23.012952","exception":false,"start_time":"2025-12-04T16:15:22.98429","status":"completed"},"tags":[]},"outputs":[],"source":["def generate_calibrated_data(start_date, end_date):\n","    \"\"\"\n","    Generate realistic market data calibrated to historical events.\n","    Uses known data points and regime-switching stochastic processes.\n","    \"\"\"\n","    print(\"Generating calibrated historical data...\")\n","    \n","    np.random.seed(42)\n","    dates = pd.date_range(start=start_date, end=end_date, freq='B')\n","    n_days = len(dates)\n","    \n","    # Initialize arrays\n","    spy_prices = np.zeros(n_days)\n","    ief_prices = np.zeros(n_days)\n","    vix_levels = np.zeros(n_days)\n","    \n","    # Convert to timestamp keys\n","    spy_known = {pd.Timestamp(k): v for k, v in HISTORICAL_SPY.items()}\n","    vix_known = {pd.Timestamp(k): v for k, v in HISTORICAL_VIX.items()}\n","    \n","    # Initialize\n","    spy_prices[0] = spy_known.get(dates[0], 146.0)\n","    ief_prices[0] = 90.0\n","    vix_levels[0] = vix_known.get(dates[0], 23.0)\n","    \n","    # Random innovations\n","    z_spy = np.random.randn(n_days)\n","    z_ief = np.random.randn(n_days)\n","    z_vix = np.random.randn(n_days)\n","    \n","    for i in range(1, n_days):\n","        date = dates[i]\n","        prev_vix = vix_levels[i-1]\n","        \n","        # Check for known values\n","        spy_target = spy_known.get(date)\n","        vix_target = vix_known.get(date)\n","        \n","        # Regime-dependent parameters\n","        if prev_vix > 50:\n","            spy_vol, spy_drift = 0.045, -0.002\n","            ief_vol, ief_drift = 0.010, 0.001\n","            vix_vol, vix_reversion = 0.10, 0.03\n","            correlation = -0.4\n","        elif prev_vix > 30:\n","            spy_vol, spy_drift = 0.025, -0.001\n","            ief_vol, ief_drift = 0.006, 0.0005\n","            vix_vol, vix_reversion = 0.06, 0.05\n","            correlation = -0.3\n","        elif prev_vix > 20:\n","            spy_vol, spy_drift = 0.012, 0.0003\n","            ief_vol, ief_drift = 0.004, 0.0002\n","            vix_vol, vix_reversion = 0.04, 0.07\n","            correlation = -0.2\n","        else:\n","            spy_vol, spy_drift = 0.008, 0.0004\n","            ief_vol, ief_drift = 0.003, 0.00015\n","            vix_vol, vix_reversion = 0.03, 0.10\n","            correlation = -0.1\n","        \n","        # Generate correlated returns\n","        z_ief_corr = correlation * z_spy[i] + np.sqrt(1 - correlation**2) * z_ief[i]\n","        \n","        # SPY\n","        if spy_target is not None:\n","            spy_prices[i] = spy_target\n","        else:\n","            spy_return = spy_drift + spy_vol * z_spy[i]\n","            spy_prices[i] = spy_prices[i-1] * np.exp(spy_return)\n","        \n","        # IEF\n","        ief_return = ief_drift + ief_vol * z_ief_corr\n","        ief_prices[i] = ief_prices[i-1] * np.exp(ief_return)\n","        \n","        # VIX\n","        if vix_target is not None:\n","            vix_levels[i] = vix_target\n","        else:\n","            vix_mean = 19.0\n","            vix_change = vix_reversion * (vix_mean - prev_vix) + vix_vol * prev_vix * z_vix[i]\n","            \n","            # Jump component for shocks\n","            if z_spy[i] < -2.5:\n","                vix_change += prev_vix * 0.15 * abs(z_spy[i])\n","            \n","            vix_levels[i] = np.clip(prev_vix + vix_change, 9, 90)\n","    \n","    # Create DataFrame\n","    data = pd.DataFrame({\n","        'SPY': spy_prices,\n","        'IEF': ief_prices,\n","        'VIX': vix_levels\n","    }, index=dates)\n","    \n","    data['SPY_Return'] = np.log(data['SPY']).diff()\n","    data['IEF_Return'] = np.log(data['IEF']).diff()\n","    \n","    print(f\"✓ Generated {len(data)} days of data\")\n","    \n","    return data"]},{"cell_type":"code","execution_count":7,"id":"7fea6c99","metadata":{"execution":{"iopub.execute_input":"2025-12-04T16:15:23.031317Z","iopub.status.busy":"2025-12-04T16:15:23.030949Z","iopub.status.idle":"2025-12-04T16:15:23.037452Z","shell.execute_reply":"2025-12-04T16:15:23.036064Z"},"papermill":{"duration":0.017703,"end_time":"2025-12-04T16:15:23.039411","exception":false,"start_time":"2025-12-04T16:15:23.021708","status":"completed"},"tags":[]},"outputs":[],"source":["def load_market_data(start_date, end_date, try_live=True):\n","    \"\"\"\n","    Load market data - tries live download first, falls back to calibrated data.\n","    \"\"\"\n","    if try_live:\n","        data = try_download_live_data(start_date, end_date)\n","        if data is not None:\n","            return data, 'live'\n","    \n","    data = generate_calibrated_data(start_date, end_date)\n","    return data, 'calibrated'"]},{"cell_type":"markdown","id":"38e8da6a","metadata":{"papermill":{"duration":0.007477,"end_time":"2025-12-04T16:15:23.054688","exception":false,"start_time":"2025-12-04T16:15:23.047211","status":"completed"},"tags":[]},"source":["## 5. VIX Term Structure Model"]},{"cell_type":"code","execution_count":8,"id":"91c7357d","metadata":{"execution":{"iopub.execute_input":"2025-12-04T16:15:23.071318Z","iopub.status.busy":"2025-12-04T16:15:23.070938Z","iopub.status.idle":"2025-12-04T16:15:23.079517Z","shell.execute_reply":"2025-12-04T16:15:23.078284Z"},"papermill":{"duration":0.019297,"end_time":"2025-12-04T16:15:23.081523","exception":false,"start_time":"2025-12-04T16:15:23.062226","status":"completed"},"tags":[]},"outputs":[],"source":["class VIXTermStructure:\n","    \"\"\"\n","    Models VIX futures term structure with regime-dependent behavior.\n","    \n","    Key patterns:\n","    - Contango (futures > spot): Normal/low vol environments\n","    - Backwardation (futures < spot): Crisis/high vol periods\n","    \"\"\"\n","    \n","    def __init__(self, vix_spot):\n","        self.vix_spot = vix_spot\n","        self.long_term_mean = 19.0\n","    \n","    def get_futures_price(self, months):\n","        \"\"\"Get VIX futures price for given months to expiry.\"\"\"\n","        \n","        if self.vix_spot > 50:\n","            # Deep backwardation during crisis\n","            discount = 0.06 * months\n","            base = self.vix_spot * (1 - discount)\n","            floor = self.long_term_mean + 15\n","            \n","        elif self.vix_spot > 30:\n","            # Moderate backwardation\n","            discount = 0.04 * months\n","            base = self.vix_spot * (1 - discount)\n","            floor = self.long_term_mean + 5\n","            \n","        elif self.vix_spot < 15:\n","            # Steep contango\n","            premium = 0.08 * months\n","            base = self.vix_spot * (1 + premium)\n","            floor = 10\n","            \n","        else:\n","            # Normal contango\n","            premium = 0.04 * months\n","            base = self.vix_spot * (1 + premium)\n","            floor = 12\n","        \n","        # Mean reversion component\n","        mean_rev = 0.5 * (1 - np.exp(-0.5 * months/12)) * (self.long_term_mean - base)\n","        \n","        return max(base + mean_rev, floor)\n","    \n","    def get_term_structure(self):\n","        \"\"\"Get full term structure.\"\"\"\n","        return {m: self.get_futures_price(m) for m in range(1, 7)}"]},{"cell_type":"code","execution_count":9,"id":"65d31829","metadata":{"execution":{"iopub.execute_input":"2025-12-04T16:15:23.098058Z","iopub.status.busy":"2025-12-04T16:15:23.097567Z","iopub.status.idle":"2025-12-04T16:15:23.106173Z","shell.execute_reply":"2025-12-04T16:15:23.104732Z"},"papermill":{"duration":0.019082,"end_time":"2025-12-04T16:15:23.107819","exception":false,"start_time":"2025-12-04T16:15:23.088737","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["VIX Term Structure Examples:\n","\n","VIX Spot: 12.0 (Low Vol) - Contango\n","  Futures: M1: 13.1 | M2: 14.1 | M3: 15.1 | M4: 16.1 | M5: 17.0 | M6: 17.9\n","\n","VIX Spot: 20.0 (Normal) - Contango\n","  Futures: M1: 20.8 | M2: 21.5 | M3: 22.2 | M4: 22.9 | M5: 23.5 | M6: 24.2\n","\n","VIX Spot: 35.0 (Elevated) - Backwardation\n","  Futures: M1: 33.3 | M2: 31.7 | M3: 30.1 | M4: 28.6 | M5: 27.2 | M6: 25.8\n","\n","VIX Spot: 70.0 (Crisis) - Backwardation\n","  Futures: M1: 64.8 | M2: 59.9 | M3: 55.1 | M4: 50.6 | M5: 46.2 | M6: 41.9\n","\n"]}],"source":["# Demonstrate term structure behavior\n","print(\"VIX Term Structure Examples:\\n\")\n","\n","for vix_spot in [12, 20, 35, 70]:\n","    ts = VIXTermStructure(vix_spot)\n","    structure = ts.get_term_structure()\n","    \n","    regime = \"Low Vol\" if vix_spot < 15 else \"Normal\" if vix_spot < 25 else \"Elevated\" if vix_spot < 40 else \"Crisis\"\n","    contango = \"Contango\" if structure[1] > vix_spot else \"Backwardation\"\n","    \n","    print(f\"VIX Spot: {vix_spot:.1f} ({regime}) - {contango}\")\n","    print(f\"  Futures: \" + \" | \".join([f\"M{m}: {p:.1f}\" for m, p in structure.items()]))\n","    print()"]},{"cell_type":"markdown","id":"6bc9af21","metadata":{"papermill":{"duration":0.007227,"end_time":"2025-12-04T16:15:23.123079","exception":false,"start_time":"2025-12-04T16:15:23.115852","status":"completed"},"tags":[]},"source":["## 6. VIX Options Pricing (Black-76 Model)"]},{"cell_type":"code","execution_count":10,"id":"6ed94c38","metadata":{"execution":{"iopub.execute_input":"2025-12-04T16:15:23.139742Z","iopub.status.busy":"2025-12-04T16:15:23.139319Z","iopub.status.idle":"2025-12-04T16:15:23.153927Z","shell.execute_reply":"2025-12-04T16:15:23.152586Z"},"papermill":{"duration":0.025292,"end_time":"2025-12-04T16:15:23.155779","exception":false,"start_time":"2025-12-04T16:15:23.130487","status":"completed"},"tags":[]},"outputs":[],"source":["# Historical VIX Options Implied Volatilities (vol of vol)\n","VIX_OPTIONS_IV = {\n","    'low_vol': {'atm': 0.70, '120pct': 0.80, '135pct': 0.90, '145pct': 1.00},\n","    'normal': {'atm': 0.80, '120pct': 0.90, '135pct': 1.00, '145pct': 1.10},\n","    'elevated': {'atm': 0.90, '120pct': 1.00, '135pct': 1.10, '145pct': 1.20},\n","    'crisis': {'atm': 1.10, '120pct': 1.25, '135pct': 1.40, '145pct': 1.50},\n","}\n","\n","class VIXOptionsPricer:\n","    \"\"\"\n","    VIX options pricer using Black-76 model.\n","    \n","    VIX options are European-style and settle based on VIX futures.\n","    Implied volatilities are calibrated to historical VIX options markets.\n","    \"\"\"\n","    \n","    def __init__(self, risk_free_rate=0.02):\n","        self.rf = risk_free_rate\n","    \n","    def get_implied_vol(self, vix_spot, moneyness):\n","        \"\"\"Get calibrated implied volatility based on VIX level and moneyness.\"\"\"\n","        \n","        # Determine regime\n","        if vix_spot > 50:\n","            regime = 'crisis'\n","        elif vix_spot > 30:\n","            regime = 'elevated'\n","        elif vix_spot < 15:\n","            regime = 'low_vol'\n","        else:\n","            regime = 'normal'\n","        \n","        iv_dict = VIX_OPTIONS_IV[regime]\n","        \n","        # Interpolate based on moneyness\n","        if moneyness <= 1.0:\n","            return iv_dict['atm']\n","        elif moneyness <= 1.20:\n","            return iv_dict['atm'] + (iv_dict['120pct'] - iv_dict['atm']) * (moneyness - 1.0) / 0.20\n","        elif moneyness <= 1.35:\n","            return iv_dict['120pct'] + (iv_dict['135pct'] - iv_dict['120pct']) * (moneyness - 1.20) / 0.15\n","        else:\n","            return iv_dict['135pct'] + (iv_dict['145pct'] - iv_dict['135pct']) * min((moneyness - 1.35) / 0.10, 1.0)\n","    \n","    def black76_call(self, F, K, T, sigma):\n","        \"\"\"\n","        Black-76 model for call options on futures.\n","        \n","        Parameters:\n","            F: Futures price\n","            K: Strike price\n","            T: Time to expiry (years)\n","            sigma: Implied volatility\n","        \n","        Returns:\n","            Call option price\n","        \"\"\"\n","        if T <= 0:\n","            return max(F - K, 0)\n","        \n","        d1 = (np.log(F / K) + 0.5 * sigma**2 * T) / (sigma * np.sqrt(T))\n","        d2 = d1 - sigma * np.sqrt(T)\n","        \n","        call_price = np.exp(-self.rf * T) * (F * norm.cdf(d1) - K * norm.cdf(d2))\n","        return call_price\n","    \n","    def price_vix_call(self, vix_spot, strike, months_to_expiry):\n","        \"\"\"\n","        Price a VIX call option.\n","        \n","        Returns:\n","            (call_price, futures_price)\n","        \"\"\"\n","        ts = VIXTermStructure(vix_spot)\n","        futures_price = ts.get_futures_price(months_to_expiry)\n","        \n","        T = months_to_expiry / 12\n","        moneyness = strike / futures_price\n","        sigma = self.get_implied_vol(vix_spot, moneyness)\n","        \n","        call_price = self.black76_call(futures_price, strike, T, sigma)\n","        \n","        return call_price, futures_price"]},{"cell_type":"code","execution_count":11,"id":"06b7a882","metadata":{"execution":{"iopub.execute_input":"2025-12-04T16:15:23.172387Z","iopub.status.busy":"2025-12-04T16:15:23.172003Z","iopub.status.idle":"2025-12-04T16:15:23.190139Z","shell.execute_reply":"2025-12-04T16:15:23.188721Z"},"papermill":{"duration":0.028755,"end_time":"2025-12-04T16:15:23.19192","exception":false,"start_time":"2025-12-04T16:15:23.163165","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["VIX Call Option Prices (per contract = price × 100)\n","\n","VIX Spot   Strike     Months     Price      Contract     Futures   \n","--------------------------------------------------------------\n","15         18         4          $3.04     $304      17.5\n","15         21         4          $2.42     $242      17.5\n","15         24         4          $2.20     $220      17.5\n","\n","25         28         4          $5.22     $522      28.2\n","25         34         4          $3.88     $388      28.2\n","25         38         4          $3.54     $354      28.2\n","\n","50         40         4          $8.29     $829      40.2\n","50         48         4          $6.51     $651      40.2\n","50         54         4          $5.96     $596      40.2\n","\n"]}],"source":["# Demonstrate options pricing\n","pricer = VIXOptionsPricer()\n","\n","print(\"VIX Call Option Prices (per contract = price × 100)\\n\")\n","print(f\"{'VIX Spot':<10} {'Strike':<10} {'Months':<10} {'Price':<10} {'Contract':<12} {'Futures':<10}\")\n","print(\"-\" * 62)\n","\n","for vix in [15, 25, 50]:\n","    for mon in [1.0, 1.20, 1.35]:\n","        ts = VIXTermStructure(vix)\n","        futures = ts.get_futures_price(4)\n","        strike = round(futures * mon)\n","        \n","        price, fut = pricer.price_vix_call(vix, strike, 4)\n","        \n","        print(f\"{vix:<10} {strike:<10} {4:<10} ${price:,.2f}     ${price*100:,.0f}      {fut:.1f}\")\n","    print()"]},{"cell_type":"markdown","id":"3c90fe73","metadata":{"papermill":{"duration":0.009218,"end_time":"2025-12-04T16:15:23.20921","exception":false,"start_time":"2025-12-04T16:15:23.199992","status":"completed"},"tags":[]},"source":["## 7. VIX Call Ladder Strategy"]},{"cell_type":"code","execution_count":12,"id":"f8ee6bb8","metadata":{"execution":{"iopub.execute_input":"2025-12-04T16:15:23.227967Z","iopub.status.busy":"2025-12-04T16:15:23.226685Z","iopub.status.idle":"2025-12-04T16:15:23.240007Z","shell.execute_reply":"2025-12-04T16:15:23.238725Z"},"papermill":{"duration":0.023955,"end_time":"2025-12-04T16:15:23.241698","exception":false,"start_time":"2025-12-04T16:15:23.217743","status":"completed"},"tags":[]},"outputs":[],"source":["class VIXCallLadder:\n","    \"\"\"\n","    VIX call ladder hedging strategy.\n","    \n","    Strategy:\n","    - Allocate fixed percentage (25 bps) of portfolio monthly to VIX calls\n","    - Purchase at specified moneyness relative to VIX futures\n","    - Build ladder across multiple expiries\n","    - Roll positions monthly\n","    \"\"\"\n","    \n","    def __init__(self, moneyness=1.20, ladder_months=4):\n","        self.moneyness = moneyness\n","        self.ladder_months = ladder_months\n","        self.pricer = VIXOptionsPricer()\n","        self.positions = {}\n","    \n","    def get_strike(self, futures_price):\n","        \"\"\"Calculate strike with realistic rounding.\"\"\"\n","        raw = futures_price * self.moneyness\n","        if raw < 20:\n","            return round(raw * 2) / 2  # Round to 0.50\n","        elif raw < 50:\n","            return round(raw)  # Round to 1.00\n","        else:\n","            return round(raw / 2.5) * 2.5  # Round to 2.50\n","    \n","    def buy_options(self, date, vix_spot, allocation):\n","        \"\"\"Buy VIX call options.\"\"\"\n","        \n","        ts = VIXTermStructure(vix_spot)\n","        futures_price = ts.get_futures_price(self.ladder_months)\n","        strike = self.get_strike(futures_price)\n","        \n","        call_price, _ = self.pricer.price_vix_call(vix_spot, strike, self.ladder_months)\n","        \n","        contract_value = call_price * 100  # VIX multiplier\n","        \n","        if contract_value > 0:\n","            num_contracts = int(allocation / contract_value)\n","            cost = num_contracts * contract_value\n","        else:\n","            num_contracts = 0\n","            cost = 0\n","        \n","        expiry = date + timedelta(days=self.ladder_months * 30)\n","        \n","        position = {\n","            'entry_date': date,\n","            'expiry_date': expiry,\n","            'strike': strike,\n","            'contracts': num_contracts,\n","            'entry_price': call_price,\n","            'entry_cost': cost,\n","            'futures_price': futures_price,\n","            'entry_vix': vix_spot\n","        }\n","        \n","        self.positions[expiry] = position\n","        return position\n","    \n","    def value_and_settle(self, date, vix_spot):\n","        \"\"\"\n","        Value positions and settle expired ones.\n","        \n","        Returns:\n","            (total_mark_to_market_value, cash_from_settlements)\n","        \"\"\"\n","        total_value = 0\n","        cash = 0\n","        expired = []\n","        \n","        for expiry, pos in self.positions.items():\n","            if date >= expiry:\n","                # Settlement (VRO typically ~3% below spot)\n","                settlement_vix = vix_spot * 0.97\n","                intrinsic = max(settlement_vix - pos['strike'], 0)\n","                cash += intrinsic * 100 * pos['contracts']\n","                expired.append(expiry)\n","            else:\n","                # Mark to market\n","                days_left = (expiry - date).days\n","                months_left = max(days_left / 30, 0.1)\n","                \n","                current_price, _ = self.pricer.price_vix_call(\n","                    vix_spot, pos['strike'], months_left\n","                )\n","                \n","                # Add convexity during VIX spikes\n","                if vix_spot > pos['entry_vix'] * 1.5:\n","                    gamma_adj = 1.0 + 0.1 * (vix_spot / pos['entry_vix'] - 1.5)\n","                    current_price *= min(gamma_adj, 1.5)\n","                \n","                total_value += current_price * 100 * pos['contracts']\n","        \n","        for exp in expired:\n","            del self.positions[exp]\n","        \n","        return total_value, cash\n","    \n","    def reset(self):\n","        \"\"\"Clear all positions.\"\"\"\n","        self.positions = {}"]},{"cell_type":"markdown","id":"bbb703c7","metadata":{"papermill":{"duration":0.007082,"end_time":"2025-12-04T16:15:23.256231","exception":false,"start_time":"2025-12-04T16:15:23.249149","status":"completed"},"tags":[]},"source":["## 8. Portfolio Simulator"]},{"cell_type":"code","execution_count":13,"id":"7fa4c562","metadata":{"execution":{"iopub.execute_input":"2025-12-04T16:15:23.272608Z","iopub.status.busy":"2025-12-04T16:15:23.272204Z","iopub.status.idle":"2025-12-04T16:15:23.288789Z","shell.execute_reply":"2025-12-04T16:15:23.287539Z"},"papermill":{"duration":0.02752,"end_time":"2025-12-04T16:15:23.290713","exception":false,"start_time":"2025-12-04T16:15:23.263193","status":"completed"},"tags":[]},"outputs":[],"source":["class PortfolioSimulator:\n","    \"\"\"\n","    Simulates a 60/40 portfolio with optional VIX call ladder overlay.\n","    \"\"\"\n","    \n","    def __init__(self, initial_value, stock_alloc=0.60, bond_alloc=0.40,\n","                 vix_bps=25, moneyness=1.20, ladder_months=4):\n","        self.initial_value = initial_value\n","        self.stock_alloc = stock_alloc\n","        self.bond_alloc = bond_alloc\n","        self.vix_bps = vix_bps\n","        self.moneyness = moneyness\n","        self.ladder_months = ladder_months\n","        self.vix_ladder = VIXCallLadder(moneyness, ladder_months)\n","        self.reset()\n","    \n","    def reset(self):\n","        self.portfolio_value = self.initial_value\n","        self.stock_value = self.initial_value * self.stock_alloc\n","        self.bond_value = self.initial_value * self.bond_alloc\n","        self.vix_value = 0\n","        self.cash = 0\n","        self.vix_ladder.reset()\n","        self.history = []\n","    \n","    def get_roll_dates(self, data):\n","        \"\"\"Get monthly roll dates (approximately 3rd week of each month).\"\"\"\n","        roll_dates = set()\n","        current_month = None\n","        \n","        for date in data.index:\n","            if current_month != (date.year, date.month):\n","                current_month = (date.year, date.month)\n","                month_days = [d for d in data.index \n","                             if d.month == date.month and d.year == date.year]\n","                if len(month_days) >= 15:\n","                    roll_dates.add(month_days[min(14, len(month_days)-1)])\n","        \n","        return roll_dates\n","    \n","    def run(self, data, with_hedge=True):\n","        \"\"\"Run the backtest.\"\"\"\n","        self.reset()\n","        roll_dates = self.get_roll_dates(data)\n","        \n","        for i, (date, row) in enumerate(data.iterrows()):\n","            if i == 0:\n","                self.history.append({\n","                    'Date': date,\n","                    'Portfolio_Value': self.portfolio_value,\n","                    'Stock_Value': self.stock_value,\n","                    'Bond_Value': self.bond_value,\n","                    'VIX_Value': 0,\n","                    'Cash': 0,\n","                    'VIX': row['VIX'],\n","                    'SPY_Return': 0,\n","                    'Portfolio_Return': 0\n","                })\n","                continue\n","            \n","            # Apply daily returns\n","            spy_ret = row['SPY_Return'] if pd.notna(row['SPY_Return']) else 0\n","            ief_ret = row['IEF_Return'] if pd.notna(row['IEF_Return']) else 0\n","            \n","            self.stock_value *= (1 + spy_ret)\n","            self.bond_value *= (1 + ief_ret)\n","            \n","            # Value VIX options\n","            if with_hedge and len(self.vix_ladder.positions) > 0:\n","                self.vix_value, expiry_cash = self.vix_ladder.value_and_settle(\n","                    date, row['VIX']\n","                )\n","                self.cash += expiry_cash\n","            \n","            # Roll date - rebalance and buy new VIX calls\n","            if date in roll_dates:\n","                total = self.stock_value + self.bond_value + self.vix_value + self.cash\n","                \n","                if with_hedge:\n","                    vix_alloc = total * (self.vix_bps / 10000)\n","                    pos = self.vix_ladder.buy_options(date, row['VIX'], vix_alloc)\n","                    cost = pos.get('entry_cost', 0)\n","                    \n","                    # Deduct cost\n","                    if self.cash >= cost:\n","                        self.cash -= cost\n","                    else:\n","                        remaining = cost - self.cash\n","                        self.cash = 0\n","                        assets = self.stock_value + self.bond_value\n","                        stock_frac = self.stock_value / assets if assets > 0 else 0.5\n","                        self.stock_value -= remaining * stock_frac\n","                        self.bond_value -= remaining * (1 - stock_frac)\n","                    \n","                    self.vix_value, _ = self.vix_ladder.value_and_settle(\n","                        date, row['VIX']\n","                    )\n","                \n","                # Rebalance stock/bond\n","                rebal_total = self.stock_value + self.bond_value + self.cash\n","                self.stock_value = rebal_total * self.stock_alloc\n","                self.bond_value = rebal_total * self.bond_alloc\n","                self.cash = 0\n","            \n","            self.portfolio_value = (self.stock_value + self.bond_value + \n","                                   self.vix_value + self.cash)\n","            \n","            prev = self.history[-1]['Portfolio_Value']\n","            ret = (self.portfolio_value - prev) / prev if prev > 0 else 0\n","            \n","            self.history.append({\n","                'Date': date,\n","                'Portfolio_Value': self.portfolio_value,\n","                'Stock_Value': self.stock_value,\n","                'Bond_Value': self.bond_value,\n","                'VIX_Value': self.vix_value,\n","                'Cash': self.cash,\n","                'VIX': row['VIX'],\n","                'SPY_Return': spy_ret,\n","                'Portfolio_Return': ret\n","            })\n","        \n","        return pd.DataFrame(self.history).set_index('Date')"]},{"cell_type":"markdown","id":"1a8d659d","metadata":{"papermill":{"duration":0.008165,"end_time":"2025-12-04T16:15:23.307717","exception":false,"start_time":"2025-12-04T16:15:23.299552","status":"completed"},"tags":[]},"source":["## 9. Performance Metrics"]},{"cell_type":"code","execution_count":14,"id":"9a4aa97b","metadata":{"execution":{"iopub.execute_input":"2025-12-04T16:15:23.3254Z","iopub.status.busy":"2025-12-04T16:15:23.324334Z","iopub.status.idle":"2025-12-04T16:15:23.338357Z","shell.execute_reply":"2025-12-04T16:15:23.337151Z"},"papermill":{"duration":0.025011,"end_time":"2025-12-04T16:15:23.340412","exception":false,"start_time":"2025-12-04T16:15:23.315401","status":"completed"},"tags":[]},"outputs":[],"source":["class PerformanceMetrics:\n","    \"\"\"\n","    Calculate comprehensive portfolio performance metrics.\n","    \"\"\"\n","    \n","    @staticmethod\n","    def annualized_return(returns):\n","        \"\"\"Calculate annualized return from daily returns.\"\"\"\n","        total = (1 + returns).prod() - 1\n","        years = len(returns) / 252\n","        return (1 + total) ** (1 / years) - 1 if years > 0 else 0\n","    \n","    @staticmethod\n","    def annualized_volatility(returns):\n","        \"\"\"Calculate annualized volatility.\"\"\"\n","        return returns.std() * np.sqrt(252)\n","    \n","    @staticmethod\n","    def downside_deviation(returns, mar=0):\n","        \"\"\"Calculate downside deviation (Sortino denominator).\"\"\"\n","        down = returns[returns < mar]\n","        if len(down) == 0:\n","            return 0.0001\n","        return np.sqrt(np.mean(down**2)) * np.sqrt(252)\n","    \n","    @staticmethod\n","    def sharpe_ratio(returns, rf=0.02):\n","        \"\"\"Calculate Sharpe ratio.\"\"\"\n","        excess = PerformanceMetrics.annualized_return(returns) - rf\n","        vol = PerformanceMetrics.annualized_volatility(returns)\n","        return excess / vol if vol > 0 else 0\n","    \n","    @staticmethod\n","    def sortino_ratio(returns, rf=0.02):\n","        \"\"\"Calculate Sortino ratio.\"\"\"\n","        excess = PerformanceMetrics.annualized_return(returns) - rf\n","        dd = PerformanceMetrics.downside_deviation(returns)\n","        return excess / dd if dd > 0 else 0\n","    \n","    @staticmethod\n","    def max_drawdown(values):\n","        \"\"\"Calculate maximum drawdown.\"\"\"\n","        peak = values.expanding(min_periods=1).max()\n","        dd = (values - peak) / peak\n","        return dd.min()\n","    \n","    @staticmethod\n","    def period_return(df, start, end):\n","        \"\"\"Calculate return during a specific period.\"\"\"\n","        mask = (df.index >= start) & (df.index <= end)\n","        p = df.loc[mask, 'Portfolio_Value']\n","        if len(p) < 2:\n","            return None\n","        return (p.iloc[-1] / p.iloc[0]) - 1\n","    \n","    @staticmethod\n","    def calculate_all(df):\n","        \"\"\"Calculate all performance metrics.\"\"\"\n","        returns = df['Portfolio_Return'].dropna()\n","        values = df['Portfolio_Value']\n","        \n","        metrics = {\n","            'Annualized_Return': PerformanceMetrics.annualized_return(returns),\n","            'Annualized_Volatility': PerformanceMetrics.annualized_volatility(returns),\n","            'Downside_Deviation': PerformanceMetrics.downside_deviation(returns),\n","            'Sharpe_Ratio': PerformanceMetrics.sharpe_ratio(returns),\n","            'Sortino_Ratio': PerformanceMetrics.sortino_ratio(returns),\n","            'Max_Drawdown': PerformanceMetrics.max_drawdown(values),\n","            'Total_Return': (values.iloc[-1] / values.iloc[0]) - 1,\n","            'Final_Value': values.iloc[-1]\n","        }\n","        \n","        # Crisis period analysis\n","        crises = [\n","            ('Oct_2008', '2008-10-01', '2008-10-31'),\n","            ('Q4_2008', '2008-10-01', '2008-12-31'),\n","            ('Flash_Crash', '2010-05-01', '2010-05-31'),\n","            ('Euro_Crisis', '2011-08-01', '2011-10-31'),\n","            ('Volmageddon', '2018-02-01', '2018-02-28'),\n","            ('COVID_Crash', '2020-02-20', '2020-03-23'),\n","            ('Year_2022', '2022-01-01', '2022-12-31'),\n","        ]\n","        \n","        for name, start, end in crises:\n","            ret = PerformanceMetrics.period_return(df, start, end)\n","            if ret is not None:\n","                metrics[f'{name}_Return'] = ret\n","        \n","        return metrics"]},{"cell_type":"markdown","id":"73b697ff","metadata":{"papermill":{"duration":0.007038,"end_time":"2025-12-04T16:15:23.354864","exception":false,"start_time":"2025-12-04T16:15:23.347826","status":"completed"},"tags":[]},"source":["## 10. Run the Backtest"