    "# Set style\n",
    "plt.style.use('seaborn-v0_8-darkgrid')\n",
    "sns.set_palette(\"husl\")\n",
    "\n",
    "class AITokenEconomics:\n",
    "    \"\"\"Complete economics model from silicon to application layer\"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        # Hardware Layer - H200 Configuration\n",
    "        self.gpu_provider_content = 17_500  # USD per GPU\n",
    "        self.other_server_content = 5_269   # USD per GPU\n",
    "        self.gpus_per_server = 8\n",
    "        self.server_cost = 210_154          # USD for 8 GPU server\n",
    "        self.networking_cost = 20_351       # USD\n",
    "        self.other_server_costs = 15_886    # USD\n",
    "        self.total_server_capex = 246_515   # USD\n",
    "        \n",
    "        # Financial Parameters\n",
    "        self.cost_of_capital = 0.094        # 9.4% per annum\n",
    "        self.depreciation_years = 3         # Server depreciation period\n",
    "        self.hours_per_year = 8760\n",
    "        \n",
    "        # From the image - exact values\n",
    "        self.capital_cost_per_gpu_hour = 1.06   # USD/hr/GPU\n",
    "        self.opex_per_gpu_hour = 0.35            # USD/hr/GPU\n",
    "        self.tco_per_gpu_hour = 1.41             # USD/hr/GPU\n",
    "        self.cost_per_million_tokens = 0.53      # USD/M tokens\n",
    "        \n",
    "        # Operating Costs\n",
    "        self.colocation_cost_kw_month = 110  # USD/kW/month\n",
    "        self.electricity_cost_kwh = 0.087    # USD/kWh\n",
    "        self.server_power_kw = 10.5          # kW per server (8x H200)\n",
    "        \n",
    "        # Performance Metrics - DeepSeek R1 FP8 on H200\n",
    "        self.inference_throughput = 735      # Tokens/s/GPU\n",
    "        self.utilization_rate = 0.85         # 85% utilization\n",
    "        \n",
    "        # Application Layer\n",
    "        self.tokens_per_user_month = 6_000_000  # Tokens/user/month\n",
    "        self.monthly_active_users = 1_800_000    # 1.8M MAU\n",
    "        self.arpu = 4.85                         # USD/month\n",
    "        \n",
    "        # Application economics from image\n",
    "        self.compute_cost_per_user = 3.20        # USD/month (6M tokens * 0.53/M)\n",
    "        self.gross_profit_per_user = 1.65        # USD/month\n",
    "        self.gross_margin = 34.0                 # Percentage\n",
    "        \n",
    "        # Calculate other derived metrics\n",
    "        self.calculate_metrics()\n",
    "    \n",
    "    def calculate_metrics(self):\n",
    "        \"\"\"Calculate all derived economic metrics\"\"\"\n",
    "        \n",
    "        # Total monthly metrics\n",
    "        self.total_monthly_revenue = self.arpu * self.monthly_active_users\n",
    "        self.total_monthly_compute_cost = self.compute_cost_per_user * self.monthly_active_users\n",
    "        self.total_monthly_gross_profit = self.gross_profit_per_user * self.monthly_active_users\n",
    "    \n",
    "    def create_waterfall_chart(self):\n",
    "        \"\"\"Create waterfall chart showing cost buildup\"\"\"\n",
    "        \n",
    "        fig, ax = plt.subplots(1, 1, figsize=(14, 8))\n",
    "        \n",
    "        # Define the waterfall steps\n",
    "        categories = [\n",
    "            'GPU Content\\n(per GPU)', \n",
    "            'Other Server\\nContent',\n",
    "            'Networking &\\nOther Costs',\n",
    "            'Total Server\\nCapital Cost',\n",
    "            'Capital Cost\\n(per GPU-hr)',\n",
    "            'Operating Cost\\n(per GPU-hr)',\n",
    "            'TCO\\n(per GPU-hr)',\n",
    "            'Inference Cost\\n(per M tokens)',\n",
    "            'User Compute\\nCost (monthly)',\n",
    "            'User Revenue\\n(ARPU)',\n",
    "            'Gross Profit\\n(per user)'\n",
    "        ]\n",
    "        \n",
    "        # Values for waterfall (some negative to show costs)\n",
    "        values = [\n",
    "            self.gpu_provider_content / 1000,  # Convert to thousands for readability\n",
    "            self.other_server_content / 1000,\n",
    "            (self.networking_cost + self.other_server_costs) / 1000,\n",
    "            0,  # Total (cumulative)\n",
    "            self.capital_cost_per_gpu_hour * 100,  # Scale for visibility\n",
    "            self.opex_per_gpu_hour * 100,\n",
    "            0,  # TCO total\n",
    "            self.cost_per_million_tokens * 10,\n",
    "            -self.compute_cost_per_user,\n",
    "            self.arpu,\n",
    "            self.gross_profit_per_user\n",
    "        ]\n",
    "        \n",
    "        # Calculate cumulative values\n",
    "        cumulative = []\n",
    "        running_total = 0\n",
    "        for i, val in enumerate(values):\n",
    "            if i in [3, 6]:  # Total bars\n",
    "                cumulative.append(running_total)\n",
    "            else:\n",
    "                cumulative.append(running_total)\n",
    "                running_total += val if i < 8 else -val if i == 8 else val\n",
    "        \n",
    "        # Create bars\n",
    "        colors = ['#3498db', '#3498db', '#3498db', '#2ecc71', '#e74c3c', '#e74c3c', \n",
    "                  '#2ecc71', '#f39c12', '#e74c3c', '#2ecc71', '#27ae60']\n",
    "        \n",
    "        for i, (cat, val, cum, color) in enumerate(zip(categories, values, cumulative, colors)):\n",
    "            if i in [3, 6]:  # Total bars\n",
    "                height = cumulative[i]\n",
    "                bottom = 0\n",
    "            else:\n",
    "                height = abs(val)\n",
    "                bottom = cum if val > 0 else cum - height\n",
    "            \n",
    "            ax.bar(i, height, bottom=bottom, color=color, alpha=0.7, edgecolor='black', linewidth=1.5)\n",
    "            \n",
    "            # Add value labels\n",
    "            if i < 4:\n",
    "                label_val = f'${val:.1f}K' if i < 3 else f'${cumulative[i]:.1f}K'\n",
    "            elif i < 7:\n",
    "                label_val = f'${val/100:.2f}/hr' if i < 6 else f'${cumulative[i]/100:.2f}/hr'\n",
    "            else:\n",
    "                label_val = f'${abs(val)/10:.2f}/M' if i == 7 else f'${abs(val):.2f}'\n",
    "            \n",
    "            y_pos = bottom + height/2 if i not in [3, 6] else height/2\n",
    "            ax.text(i, y_pos, label_val, ha='center', va='center', fontweight='bold', fontsize=9)\n",
    "        \n",
    "        ax.set_xticks(range(len(categories)))\n",
    "        ax.set_xticklabels(categories, rotation=45, ha='right', fontsize=10)\n",
    "        ax.set_title('AI Token Economics: Cost Waterfall from Silicon to Application', \n",
    "                     fontsize=16, fontweight='bold', pad=20)\n",
    "        ax.set_ylabel('Cost/Value (scaled for visibility)', fontsize=12)\n",
    "        ax.grid(True, alpha=0.3)\n",
    "        ax.axhline(y=0, color='black', linewidth=1)\n",
    "        \n",
    "        # Add gross margin annotation\n",
    "        ax.annotate(f'Gross Margin: {self.gross_margin:.1f}%',\n",
    "                   xy=(10, self.gross_profit_per_user/2),\n",
    "                   xytext=(10.5, 5),\n",
    "                   arrowprops=dict(arrowstyle='->', color='green', lw=2),\n",
    "                   fontsize=12, fontweight='bold', color='green')\n",
    "        \n",
    "        plt.tight_layout()\n",
    "        return fig\n",
    "    \n",
    "    def create_economics_stack_viz(self):\n",
    "        \"\"\"Create the full economics stack visualization\"\"\"\n",
    "        \n",
    "        fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 10))\n",
    "        \n",
    "        # Left side - Cost Stack Breakdown\n",
    "        layers = [\n",
    "            ('Silicon/Hardware', self.gpu_provider_content * self.gpus_per_server / 1000, '#3498db'),\n",
    "            ('Other Server Components', self.other_server_content * self.gpus_per_server / 1000, '#9b59b6'),\n",
    "            ('Networking Infrastructure', self.networking_cost / 1000, '#e67e22'),\n",
    "            ('Other Infrastructure', self.other_server_costs / 1000, '#95a5a6'),\n",
    "        ]\n",
    "        \n",
    "        bottom = 0\n",
    "        for layer, value, color in layers:\n",
    "            ax1.bar(0, value, bottom=bottom, color=color, alpha=0.8, width=0.5, \n",
    "                   edgecolor='black', linewidth=2, label=layer)\n",
    "            ax1.text(0, bottom + value/2, f'${value:.1f}K', ha='center', va='center',\n",
    "                    fontweight='bold', fontsize=11, color='white')\n",
    "            bottom += value\n",
    "        \n",
    "        ax1.set_xlim(-0.6, 0.6)\n",
    "        ax1.set_ylim(0, 260)\n",
    "        ax1.set_ylabel('Capital Cost ($K)', fontsize=12, fontweight='bold')\n",
    "        ax1.set_title('Server Capital Cost Stack\\n(8x H200 Configuration)', fontsize=14, fontweight='bold')\n",
    "        ax1.set_xticks([])\n",
    "        ax1.legend(loc='upper right', fontsize=10)\n",
    "        ax1.grid(True, alpha=0.3, axis='y')\n",
    "        \n",
    "        # Add total annotation\n",
    "        ax1.annotate(f'Total: ${self.total_server_capex/1000:.1f}K',\n",
    "                    xy=(0, bottom), xytext=(0.3, bottom + 10),\n",
    "                    arrowprops=dict(arrowstyle='->', lw=2, color='red'),\n",
    "                    fontsize=12, fontweight='bold', color='red')\n",
    "        \n",
    "        # Right side - Unit Economics Flow\n",
    "        ax2.axis('off')\n",
    "        \n",
    "        # Create flow diagram\n",
    "        boxes = [\n",
    "            ('TCO per GPU-hour', f'${self.tco_per_gpu_hour:.2f}', 0.2, 0.85, '#3498db'),\n",
    "            ('Throughput', f'{self.inference_throughput} tok/s', 0.2, 0.65, '#9b59b6'),\n",
    "            ('Cost per M tokens', f'${self.cost_per_million_tokens:.2f}', 0.2, 0.45, '#e74c3c'),\n",
    "            ('User Consumption', f'{self.tokens_per_user_month/1e6:.0f}M tok/mo', 0.5, 0.45, '#f39c12'),\n",
    "            ('Compute Cost/User', f'${self.compute_cost_per_user:.2f}', 0.2, 0.25, '#e74c3c'),\n",
    "            ('ARPU', f'${self.arpu:.2f}', 0.5, 0.25, '#27ae60'),\n",
    "            ('Gross Margin', f'{self.gross_margin:.1f}%', 0.35, 0.05, '#2ecc71'),\n",
    "        ]\n",
    "        \n",
    "        for label, value, x, y, color in boxes:\n",
    "            box = FancyBboxPatch((x-0.12, y-0.05), 0.24, 0.08,\n",
    "                                 boxstyle=\"round,pad=0.01\",\n",
    "                                 facecolor=color, alpha=0.7,\n",
    "                                 edgecolor='black', linewidth=2)\n",
    "            ax2.add_patch(box)\n",
    "            ax2.text(x, y, f'{label}\\n{value}', ha='center', va='center',\n",
    "                    fontsize=10, fontweight='bold', color='white')\n",
    "        \n",
    "        # Add arrows\n",
    "        arrows = [\n",
    "            (0.2, 0.80, 0.2, 0.73),  # TCO to Throughput\n",
    "            (0.2, 0.60, 0.2, 0.53),  # Throughput to Cost/M\n",
    "            (0.32, 0.45, 0.38, 0.45),  # Cost/M to Consumption\n",
    "            (0.2, 0.40, 0.2, 0.33),  # Cost/M to Compute Cost\n",
    "            (0.38, 0.25, 0.32, 0.25),  # ARPU to Compute Cost  \n",
    "            (0.35, 0.20, 0.35, 0.13),  # To Gross Margin\n",
    "        ]\n",
    "        \n",
    "        for x1, y1, x2, y2 in arrows:\n",
    "            ax2.annotate('', xy=(x2, y2), xytext=(x1, y1),\n",
    "                        arrowprops=dict(arrowstyle='->', lw=2, color='gray'))\n",
    "        \n",
    "        ax2.set_xlim(0, 0.7)\n",
    "        ax2.set_ylim(0, 1)\n",
    "        ax2.set_title('Unit Economics Flow\\n(Inference to Application Layer)', \n",
    "                     fontsize=14, fontweight='bold')\n",
    "        \n",
    "        fig.suptitle('AI Token Factory Economics Stack - H200 Infrastructure Analysis',\n",
    "                    fontsize=16, fontweight='bold', y=1.02)\n",
    "        \n",
    "        plt.tight_layout()\n",
    "        return fig\n",
    "    \n",
    "    def create_sensitivity_analysis(self):\n",
    "        \"\"\"Create sensitivity analysis for key parameters\"\"\"\n",
    "        \n",
    "        fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "        \n",
    "        # Sensitivity to GPU utilization\n",
    "        utilizations = np.linspace(0.5, 1.0, 50)\n",
    "        margins = []\n",
    "        for util in utilizations:\n",
    "            tokens_per_hour = self.inference_throughput * 3600 * util\n",
    "            cost_per_m = (self.tco_per_gpu_hour / tokens_per_hour) * 1_000_000\n",
    "            compute_cost = (self.tokens_per_user_month / 1_000_000) * cost_per_m\n",
    "            margin = ((self.arpu - compute_cost) / self.arpu) * 100\n",
    "            margins.append(margin)\n",
    "        \n",
    "        axes[0, 0].plot(utilizations * 100, margins, linewidth=3, color='#3498db')\n",
    "        axes[0, 0].axhline(y=34.0, color='red', linestyle='--', alpha=0.7, label='Current (34%)')\n",
    "        axes[0, 0].fill_between(utilizations * 100, margins, alpha=0.3, color='#3498db')\n",
    "        axes[0, 0].set_xlabel('GPU Utilization (%)', fontsize=11, fontweight='bold')\n",
    "        axes[0, 0].set_ylabel('Gross Margin (%)', fontsize=11, fontweight='bold')\n",
    "        axes[0, 0].set_title('Sensitivity to GPU Utilization', fontsize=12, fontweight='bold')\n",
    "        axes[0, 0].grid(True, alpha=0.3)\n",
    "        axes[0, 0].legend()\n",
    "        \n",
    "        # Sensitivity to inference throughput\n",
    "        throughputs = np.linspace(400, 1200, 50)\n",
    "        margins_tp = []\n",
    "        for tp in throughputs:\n",
    "            tokens_per_hour = tp * 3600 * self.utilization_rate\n",
    "            cost_per_m = (self.tco_per_gpu_hour / tokens_per_hour) * 1_000_000\n",
    "            compute_cost = (self.tokens_per_user_month / 1_000_000) * cost_per_m\n",
    "            margin = ((self.arpu - compute_cost) / self.arpu) * 100\n",
    "            margins_tp.append(margin)\n",
    "        \n",
    "        axes[0, 1].plot(throughputs, margins_tp, linewidth=3, color='#2ecc71')\n",
    "        axes[0, 1].axvline(x=self.inference_throughput, color='red', linestyle='--', alpha=0.7, label='Current (735 tok/s)')\n",
    "        axes[0, 1].fill_between(throughputs, margins_tp, alpha=0.3, color='#2ecc71')\n",
    "        axes[0, 1].set_xlabel('Inference Throughput (tokens/s/GPU)', fontsize=11, fontweight='bold')\n",
    "        axes[0, 1].set_ylabel('Gross Margin (%)', fontsize=11, fontweight='bold')\n",
    "        axes[0, 1].set_title('Sensitivity to Model Efficiency', fontsize=12, fontweight='bold')\n",
    "        axes[0, 1].grid(True, alpha=0.3)\n",
    "        axes[0, 1].legend()\n",
    "        \n",
    "        # Sensitivity to ARPU\n",
    "        arpus = np.linspace(2, 10, 50)\n",
    "        margins_arpu = []\n",
    "        for arpu in arpus:\n",
    "            margin = ((arpu - self.compute_cost_per_user) / arpu) * 100\n",
    "            margins_arpu.append(margin)\n",
    "        \n",
    "        axes[1, 0].plot(arpus, margins_arpu, linewidth=3, color='#e74c3c')\n",
    "        axes[1, 0].axvline(x=self.arpu, color='red', linestyle='--', alpha=0.7, label=f'Current (${self.arpu:.2f})')\n",
    "        axes[1, 0].fill_between(arpus, margins_arpu, alpha=0.3, color='#e74c3c')\n",
    "        axes[1, 0].set_xlabel('Average Revenue Per User ($/month)', fontsize=11, fontweight='bold')\n",
    "        axes[1, 0].set_ylabel('Gross Margin (%)', fontsize=11, fontweight='bold')\n",
    "        axes[1, 0].set_title('Sensitivity to Pricing', fontsize=12, fontweight='bold')\n",
    "        axes[1, 0].grid(True, alpha=0.3)\n",
    "        axes[1, 0].legend()\n",
    "        \n",
    "        # ROI Analysis\n",
    "        scales = np.linspace(0.5, 5, 50)  # Scale factor for MAU\n",
    "        rois = []\n",
    "        for scale in scales:\n",
    "            scaled_mau = self.monthly_active_users * scale\n",
    "            monthly_profit = self.gross_profit_per_user * scaled_mau\n",
    "            annual_profit = monthly_profit * 12\n",
    "            servers_needed = np.ceil((scaled_mau * self.tokens_per_user_month) / \n",
    "                                    (self.inference_throughput * 3600 * 24 * 30 * \n",
    "                                     self.gpus_per_server * self.utilization_rate * 1e6))\n",
    "            total_capex = servers_needed * self.total_server_capex\n",
    "            roi = (annual_profit / total_capex) * 100 if total_capex > 0 else 0\n",
    "            rois.append(roi)\n",
    "        \n",
    "        axes[1, 1].plot(scales * self.monthly_active_users / 1e6, rois, linewidth=3, color='#9b59b6')\n",
    "        axes[1, 1].axvline(x=self.monthly_active_users / 1e6, color='red', linestyle='--', alpha=0.7, label='Current')\n",
    "        axes[1, 1].fill_between(scales * self.monthly_active_users / 1e6, rois, alpha=0.3, color='#9b59b6')\n",
    "        axes[1, 1].set_xlabel('Monthly Active Users (millions)', fontsize=11, fontweight='bold')\n",
    "        axes[1, 1].set_ylabel('Annual ROI (%)', fontsize=11, fontweight='bold')\n",
    "        axes[1, 1].set_title('Return on Investment vs Scale', fontsize=12, fontweight='bold')\n",
    "        axes[1, 1].grid(True, alpha=0.3)\n",
    "        axes[1, 1].legend()\n",
    "        \n",
    "        fig.suptitle('Sensitivity Analysis: Key Economics Drivers', fontsize=16, fontweight='bold')\n",
    "        plt.tight_layout()\n",
    "        return fig\n",
    "    \n",
    "    def create_power_requirements_chart(self):\n",
    "        \"\"\"Create chart showing power requirements scaling\"\"\"\n",
    "        \n",
    "        fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))\n",
    "        \n",
    "        # Power scaling with token demand\n",
    "        token_demands = np.linspace(1e12, 1e14, 100)  # Monthly tokens\n",
    "        \n",
    "        megawatts = []\n",
    "        for demand in token_demands:\n",
    "            tokens_per_gpu_month = self.inference_throughput * 3600 * 24 * 30 * self.utilization_rate\n",
    "            gpus_needed = demand / tokens_per_gpu_month\n",
    "            servers_needed = gpus_needed / self.gpus_per_server\n",
    "            power_mw = servers_needed * self.server_power_kw / 1000\n",
    "            megawatts.append(power_mw)\n",
    "        \n",
    "        ax1.loglog(token_demands / 1e12, megawatts, linewidth=3, color='#e74c3c')\n",
    "        ax1.fill_between(token_demands / 1e12, megawatts, alpha=0.3, color='#e74c3c')\n",
    "        ax1.set_xlabel('Monthly Token Demand (Trillions)', fontsize=11, fontweight='bold')\n",
    "        ax1.set_ylabel('Power Requirements (MW)', fontsize=11, fontweight='bold')\n",
    "        ax1.set_title('Infrastructure Power Scaling', fontsize=12, fontweight='bold')\n",
    "        ax1.grid(True, alpha=0.3, which='both')\n",
    "        \n",
    "        # Current position\n",
    "        current_demand = self.monthly_active_users * self.tokens_per_user_month\n",
    "        current_power = (current_demand / (self.inference_throughput * 3600 * 24 * 30 * \n",
    "                        self.utilization_rate * self.gpus_per_server)) * self.server_power_kw / 1000\n",
    "        ax1.scatter(current_demand / 1e12, current_power, color='red', s=100, zorder=5, \n",
    "                   label='Current Scale')\n",
    "        ax1.legend()\n",
    "        \n",
    "        # Cost per MW breakdown\n",
    "        categories = ['Capital Cost', 'Electricity', 'Colocation', 'Total']\n",
    "        \n",
    "        # Calculate monthly costs per MW\n",
    "        mw_servers = 1000 / self.server_power_kw  # Servers per MW\n",
    "        mw_capex_monthly = (mw_servers * self.total_server_capex * self.cost_of_capital) / 12\n",
    "        mw_electricity = 1000 * 24 * 30 * self.electricity_cost_kwh\n",
    "        mw_colocation = 1000 * self.colocation_cost_kw_month\n",
    "        \n",
    "        values = [mw_capex_monthly/1000, mw_electricity/1000, mw_colocation/1000,\n",
    "                 (mw_capex_monthly + mw_electricity + mw_colocation)/1000]\n",
    "        colors = ['#3498db', '#f39c12', '#9b59b6', '#2ecc71']\n",
    "        \n",
    "        bars = ax2.bar(categories, values, color=colors, alpha=0.8, edgecolor='black', linewidth=2)\n",
    "        \n",
    "        for bar, val in zip(bars, values):\n",
    "            height = bar.get_height()\n",
    "            ax2.text(bar.get_x() + bar.get_width()/2, height + 1,\n",
    "                    f'${val:.1f}K', ha='center', va='bottom', fontweight='bold')\n",
    "        \n",
    "        ax2.set_ylabel('Monthly Cost per MW ($K)', fontsize=11, fontweight='bold')\n",
    "        ax2.set_title('Cost Structure per Megawatt', fontsize=12, fontweight='bold')\n",
    "        ax2.grid(True, alpha=0.3, axis='y')\n",
    "        \n",
    "        fig.suptitle('Power Requirements & Economics', fontsize=16, fontweight='bold')\n",
    "        plt.tight_layout()\n",
    "        return fig\n",
    "    \n",
    "    def generate_report(self):\n",
    "        \"\"\"Generate comprehensive economics report\"\"\"\n",
    "        \n",
    "        report = f\"\"\"\n",
    "=================================================================\n",
